<div class="container">
  <div class="columns is-centered">
    <div class="column is-8">
      <h1 class="title is-3 mb-5">Search</h1>

      <div class="box">
        <%= form_with url: users_path, method: :get, local: true do %>
          <div class="field has-addons">
            <div class="control is-expanded">
              <%= text_field_tag :q,
                                 @query,
                                 class: "input",
                                 placeholder: "Search by first name, last name, or email" %>
            </div>
            <div class="control">
              <%= submit_tag "Search", class: "button is-primary" %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @users.any? %>
        <% @users.each do |user| %>
          <div class="box">
            <div class="is-flex is-justify-content-space-between is-align-items-center">
              <div>
                <p class="title is-5 mb-1">
                  <%= link_to(
                        [user.first_name, user.last_name].join(" ").strip.presence || user.email_address,
                        user_path(user),
                        class: "has-text-dark"
                      ) %>
                </p>

                <p class="is-size-7 has-text-grey mb-2">
                  <%= user.email_address %>
                </p>

                <div class="is-flex is-align-items-center" style="gap: 0.75rem; flex-wrap: wrap;">
                  <% if user.is_verified? %>
                    <span class="tag is-success is-light">Verified</span>
                  <% else %>
                    <span class="tag is-light">Unverified</span>
                  <% end %>
                </div>
              </div>

              <% if Current.user&.admin? %>
                <div class="buttons">
                  <%= button_to(
                        user.is_verified? ? "Unverify" : "Verify",
                        toggle_verification_user_path(user),
                        method: :patch,
                        data: {
                          turbo_confirm: user.is_verified? ? "Unverify this user?" : "Verify this user?"
                        },
                        class: user.is_verified? ? "button is-warning is-light" : "button is-success is-light"
                      ) %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="notification is-light has-text-centered">
          No users found.
        </div>
      <% end %>
    </div>
  </div>
</div>