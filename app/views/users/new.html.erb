<div class="container">
  <div class="columns is-centered">
    <div class="column is-6">
      <h1 class="title is-3 has-text-centered mb-5">Sign Up</h1>

      <%= form_with model: @user, url: users_path do |form| %>
        <% if @user.errors.any? %>
          <div class="notification is-danger is-light">
            <p class="mb-2">
              <strong><%= pluralize(@user.errors.count, "error") %> prevented sign up:</strong>
            </p>
            <ul>
              <% @user.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="box">
          <div class="field">
            <%= form.label :first_name, class: "label" %>
            <div class="control">
              <%= form.text_field :first_name, class: "input", placeholder: "First name" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :last_name, class: "label" %>
            <div class="control">
              <%= form.text_field :last_name, class: "input", placeholder: "Last name" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :email_address, class: "label" %>
            <div class="control">
              <%= form.email_field :email_address, class: "input", placeholder: "Email address" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :phone, class: "label" %>
            <div class="control">
              <%= form.text_field :phone, class: "input", placeholder: "Phone number" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :address, class: "label" %>
            <div class="control">
              <%= form.text_area :address, class: "textarea", rows: 3, placeholder: "Address" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :password, class: "label" %>
            <div class="control">
              <%= form.password_field :password, class: "input", placeholder: "Password" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :password_confirmation, class: "label" %>
            <div class="control">
              <%= form.password_field :password_confirmation, class: "input", placeholder: "Confirm password" %>
            </div>
          </div>

          <div class="field mt-5">
            <div class="control">
              <%= form.submit "Create Account", class: "button is-primary is-fullwidth" %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="has-text-centered mt-4">
        <%= link_to "Already have an account? Sign in", new_session_path, class: "is-size-7" %>
      </div>
    </div>
  </div>
</div>