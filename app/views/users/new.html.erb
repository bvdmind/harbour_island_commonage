<h1 class="title">Sign Up</h1>

<div class="login">
  <%= form_with model: @user, url: users_path do |form| %>
    <% if @user.errors.any? %>
      <div class="notification is-danger">
        <p><strong><%= pluralize(@user.errors.count, "error") %> prevented sign up:</strong></p>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= form.label :first_name, class: "label" %>
      <div class="control">
        <%= form.text_field :first_name, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :last_name, class: "label" %>
      <div class="control">
        <%= form.text_field :last_name, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :email_address, class: "label" %>
      <div class="control">
        <%= form.email_field :email_address, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :phone, class: "label" %>
      <div class="control">
        <%= form.text_field :phone, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :address, class: "label" %>
      <div class="control">
        <%= form.text_area :address, class: "textarea is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :password, class: "label" %>
      <div class="control">
        <%= form.password_field :password, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :password_confirmation, class: "label" %>
      <div class="control">
        <%= form.password_field :password_confirmation, class: "input is-medium is-rounded" %>
      </div>
    </div>

    <div class="control">
      <%= form.submit "Create Account", class: "button is-primary" %>
    </div>
  <% end %>
</div>

<p class="mt-4">
  <%= link_to "Already have an account? Sign in", new_session_path %>
</p>