<div class="container">
  <div class="columns is-centered">
    <div class="column is-7">
      <h1 class="title is-3 mb-5">Upload Document</h1>

      <%= form_with model: @document, url: documents_path, local: true do |form| %>
        <% if @document.errors.any? %>
          <div class="notification is-danger is-light">
            <ul>
              <% @document.errors.full_messages.each do |msg| %>
                <li>• <%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="box">
          <div class="field">
            <%= form.label :document_type, class: "label" %>
            <div class="control">
              <%= form.text_field :document_type,
                    class: "input",
                    placeholder: "e.g. ID, Passport, Forms" %>
            </div>
          </div>

          <div class="field">
            <%= form.label :notes, class: "label" %>
            <div class="control">
              <%= form.text_area :notes,
                    class: "textarea",
                    rows: 4,
                    placeholder: "Optional notes..." %>
            </div>
          </div>

          <div class="field">
            <label class="label">Upload File</label>
            <div class="control">
              <div class="file has-name is-fullwidth" data-controller="file-name">
                <label class="file-label">
                  <%= form.file_field :file,
                        class: "file-input",
                        data: { action: "change->file-name#update" } %>

                  <span class="file-cta">
                    <span class="file-icon">
                      <i class="fas fa-upload"></i>
                    </span>
                    <span class="file-label">
                      Choose a file…
                    </span>
                  </span>

                  <span class="file-name" data-file-name-target="name">
                    No file selected
                  </span>
                </label>
              </div>
            </div>
          </div>

          <div class="field is-grouped mt-5">
            <div class="control">
              <%= form.submit "Upload", class: "button is-primary" %>
            </div>

            <div class="control">
              <%= link_to "Back", documents_path, class: "button is-light" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>