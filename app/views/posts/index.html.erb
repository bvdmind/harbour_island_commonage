<% if Current.user&.admin? %>
  <div class="container mb-5">
    <div class="is-flex is-justify-content-flex-end">
      <%= link_to "New Post", new_post_path, class: "button is-primary is-medium" %>
    </div>
  </div>
<% end %>

<% if @posts.any? %>
  <div class="container">
    <% @posts.each do |post| %>
      <div class="card mb-6">
        <% if post.image.attached? %>
          <div class="card-image">
            <figure class="image is-16by9">
              <%= image_tag post.image, class: "has-ratio" %>
            </figure>
          </div>
        <% end %>

        <div class="card-content">
          <div class="media">
            <div class="media-content">
              <p class="title is-4 mb-2">
                <%= link_to post.title, post_path(post), class: "has-text-dark" %>
              </p>
              <br>
              <p class="subtitle is-6 has-text-grey mb-2">
                <%= [post.user.first_name, post.user.last_name].join(" ").strip.presence || post.user.email_address %>
              </p>
              <p class="is-size-7 has-text-grey">
                <%= post.created_at.strftime("%B %d, %Y at %I:%M %p") %>
              </p>
            </div>
          </div>

          <div class="content">
            <%= truncate(post.body, length: 200) %>
          </div>

          <% if Current.user&.admin? %>
            <div class="buttons mt-4">
              <%= link_to "Edit", edit_post_path(post), class: "button is-link is-light" %>
              <%= link_to "Delete",
                          post_path(post),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "button is-danger is-light" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="container">
    <div class="notification is-light has-text-centered">
      No posts yet.
    </div>
  </div>
<% end %>