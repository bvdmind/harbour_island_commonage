<h1>Main Feed</h1>

<% if Current.user&.admin? %>
  <p><%= link_to "New Post", new_post_path %></p>
<% end %>

<% if @posts.any? %>
  <% @posts.each do |post| %>
    <div style="border: 1px solid #ccc; padding: 12px; margin-bottom: 12px;">
      <h2><%= link_to post.title, post_path(post) %></h2>

      <p>
        Posted by
        <%= [post.user.first_name, post.user.last_name].join(" ").strip.presence || post.user.email_address %>
        on
        <%= post.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>

      <p><%= truncate(post.body, length: 200) %></p>

      <% if Current.user&.admin? %>
        <p>
          <%= link_to "Edit", edit_post_path(post) %> |
          <%= link_to "Delete", post_path(post), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
        </p>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p>No posts yet.</p>
<% end %>