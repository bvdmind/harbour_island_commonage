<div class="container">
  <div class="columns is-centered">
    <div class="column is-8">
      <div class="box">
        <div class="is-flex is-align-items-center mb-5">
          <div class="mr-5">
            <% if @user.photo.attached? %>
              <figure class="image is-128x128">
                <%= image_tag @user.photo, class: "is-rounded" %>
              </figure>
            <% else %>
              <figure class="image is-128x128">
                <img class="is-rounded" src="https://bulma.io/assets/images/placeholders/128x128.png" alt="Profile placeholder">
              </figure>
            <% end %>
          </div>
          <div>
            <p class="title is-4 mb-2">
              <%= [@user.first_name, @user.last_name].join(" ").split.map(&:capitalize).join(" ") %>
            </p>
            <br>
            <p class="subtitle is-6 mb-1">
              <strong>Phone:</strong> <%= @user.phone.presence || "N/A" %>
            </p>

            <p class="subtitle is-6 mb-1">
              <strong>Address:</strong> <%= @user.address.presence&.capitalize || "N/A" %>
            </p>

            <p class="subtitle is-6">
              <strong>Verified:</strong>
              <% if @user.is_verified? %>
                <span class="tag is-success is-light">Yes</span>
              <% else %>
                <span class="tag is-danger is-light">No</span>
              <% end %>
            </p>

            <% if Current.user == @user %>
              <div class="mt-3">
                <%= link_to "Edit Profile", edit_profile_path, class: "button is-primary is-light" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <h2 class="title is-4 mt-6">Properties</h2>

      <% if @user.properties.any? %>
        <% @user.properties.each do |property| %>
          <div class="box">
            <p><strong>Name:</strong> <%= property.name %></p>
            <p><strong>Reference:</strong> <%= property.commonage_reference.presence || "N/A" %></p>
            <p><strong>Address:</strong> <%= property.address.presence || "N/A" %></p>
          </div>
        <% end %>
      <% else %>
        <div class="notification is-light">
          No properties linked yet.
        </div>
      <% end %>

      <% if Current.user&.admin? || Current.user == @user %>
        <h2 class="title is-4 mt-6">Documents</h2>

        <% if @user.documents.any? %>
          <% @user.documents.each do |doc| %>
            <div class="box">
              <p><strong>Type:</strong> <%= doc.document_type %></p>
              <p><strong>Notes:</strong> <%= doc.notes.presence || "None" %></p>
              <p><strong>Uploaded:</strong> <%= doc.created_at.strftime("%B %d, %Y") %></p>

              <div class="mt-3">
                <% if doc.file.attached? %>
                  <%= link_to "View File",
                              url_for(doc.file),
                              class: "button is-link is-light",
                              target: "_blank" %>
                <% else %>
                  <span class="has-text-grey">No file attached.</span>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="notification is-light">
            No documents uploaded.
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>